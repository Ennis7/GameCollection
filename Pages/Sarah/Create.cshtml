@page
@model GameCollection.Pages.Sarah.CreateModel
@using GameCollection.Models

@{
    ViewData["Title"] = "Create";
}
<link rel="stylesheet" href="~/css/Sarah.css" asp-append-version="true" />
<h1>Create</h1>

<hr />
<dl>
<div class="row">
    <dt class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Games.Title" class="control-label"></label>
                <input asp-for="Games.Title" class="form-control" />
                <span asp-validation-for="Games.Title" class="text-danger"></span>
                <br />
            </div>
            <div class="form-group">
                <label asp-for="Games.GenreType" class="control-label"></label>
                <select asp-for="Games.GenreType" asp-items="Html.GetEnumSelectList<Models.Genre>()" class="form-control">
                    <option value="">Choose a genre</option>
                </select>
                <span asp-validation-for="Games.GenreType" class="text-danger"></span>
                <br />
            </div>
            <div class="form-group">
                <label asp-for="Games.Developer" class="control-label"></label>
                <input asp-for="Games.Developer" class="form-control" />
                <span asp-validation-for="Games.Developer" class="text-danger"></span>
                <br />
            </div>
            <div class="form-group">
                <label asp-for="Games.ReleaseDate" class="control-label"></label>
                <input asp-for="Games.ReleaseDate" class="form-control" />
                <span asp-validation-for="Games.ReleaseDate" class="text-danger"></span>
                <br />
            </div>
            <div class="form-group">
                <label asp-for="Games.Price" class="control-label"></label>
                <input asp-for="Games.Price" class="form-control" />
                <span asp-validation-for="Games.Price" class="text-danger"></span>
                <br />
            </div>
            <div class="form-group">
                <label asp-for="Games.OwnerID" class="control-label"></label>
                <select asp-for="Games.OwnerID" class ="form-control" asp-items="ViewBag.OwnerID"></select>
                <br />
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a class="btn btn-secondary" asp-page="./Index">Back to List</a>
            </div>
        </form>
    </dt>
</div>
</dl>
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
